# ── Anthropic (AI Mentor + Challenge Generator) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/winlab

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...           # Test mode secret key
STRIPE_WEBHOOK_SECRET=whsec_...         # Webhook signing secret (from Stripe CLI or dashboard)

# Subscription Price IDs (create these in Stripe Dashboard)
# Format: STRIPE_PRICE_<PLAN>_<CURRENCY>
STRIPE_PRICE_PRO=price_...              # $19/mo USD - Pro plan
STRIPE_PRICE_PRO_INR=price_...          # ₹199/mo INR - Pro plan (India)
STRIPE_PRICE_BUSINESS=price_...         # $99/mo USD - Business plan
STRIPE_PRICE_BUSINESS_INR=price_...     # ₹999/mo INR - Business plan (India)

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://winlab.io
JWT_SECRET=change-me-in-production

# ── Email Service (Resend) ───────────────────────────────────────────────────
# Get API key from: https://resend.com/api-keys
# Leave empty in development — emails are logged instead of sent
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@winlab.cloud

# ── Encryption (AES-256-CTR for sensitive fields) ────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-in-production

# ── Helpdesk (Mini Zendesk) ──────────────────────────────────────────────────
# Optional: Gmail API credentials for email ingestion
# Leave empty to use manual ingest via POST /api/helpdesk/ingest
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
HELPDESK_EMAIL_FROM=support@winlab.cloud

# ── Social Media URLs ────────────────────────────────────────────────────────
VITE_SOCIAL_TIKTOK=https://tiktok.com/@yourhandle
VITE_SOCIAL_YOUTUBE=https://youtube.com/@yourchannel
VITE_SOCIAL_LINKEDIN=https://linkedin.com/company/yourcompany
VITE_SOCIAL_INSTAGRAM=https://instagram.com/yourhandle
VITE_SOCIAL_FACEBOOK=https://facebook.com/yourpage
